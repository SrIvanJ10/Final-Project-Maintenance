# Django
DEBUG=True
SECRET_KEY=your-secret-key-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=myscience_db
DB_USER=myscience_user
DB_PASSWORD=myscience_password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Semantic Scholar API
SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-api-key
SEMANTIC_SCHOLAR_API_TIMEOUT=30
SEMANTIC_SCHOLAR_API_MAX_RETRIES=5
SEMANTIC_SCHOLAR_API_BACKOFF_FACTOR=1.5
SEMANTIC_SCHOLAR_API_MIN_REQUEST_INTERVAL=1.05
SEMANTIC_SCHOLAR_RESULTS_PER_KEYWORD=20
SEMANTIC_SCHOLAR_USE_BULK_SEARCH=True

# LLM APIs
LLM_API_TIMEOUT=60

OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Email Configuration (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-password
COMPOSE_PROJECT_NAME=myscience
